{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "installCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/condo-association-management", "destination": "/condo-management", "permanent": true },
    { "source": "/condo-association-management/", "destination": "/condo-management", "permanent": true },
    { "source": "/service-area/anne-arundel-county-md", "destination": "/rental-management/maryland/anne-arundel-county", "permanent": true },
    { "source": "/service-area/anne-arundel-county-md/", "destination": "/rental-management/maryland/anne-arundel-county", "permanent": true },
    { "source": "/service-area/silver-spring-md", "destination": "/rental-management/maryland/silver-spring", "permanent": true },
    { "source": "/service-area/silver-spring-md/", "destination": "/rental-management/maryland/silver-spring", "permanent": true },
    { "source": "/blog/what-does-a-community-association-manager-do", "destination": "/blog/what-is-a-community-association-manager", "permanent": true },
    { "source": "/blog/what-does-a-community-association-manager-do/", "destination": "/blog/what-is-a-community-association-manager", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
