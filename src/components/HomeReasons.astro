---
const items = [
  { n: '01', title: 'A manager who knows your community',  body: 'Average tenure across our management leadership exceeds a decade. The same person — not a rotating roster — runs your account.' },
  { n: '02', title: "A real human answers when it's 2am",  body: 'After-hours line is answered by Tidewater community managers, not an answering service. 20-minute callback standard, every time.' },
  { n: '03', title: 'Financials boards can actually read',  body: 'Clean, board-readable monthly reports on the 1st. Real-time delinquency visibility via portal. Optional secondary invoice approval.' },
  { n: '04', title: 'A second set of eyes on every plan',   body: 'Annual management plans are tracked across the portfolio by our QA team — so deadlines, inspections, and renewals never slip past your manager.' },
];
---
<section class="tw-section">
  <div class="tw-container">
    <div class="tw-section-head">
      <div class="tw-eyebrow">Why Boards Choose Tidewater</div>
      <h2 class="tw-section-title">Hands-on operations. <em>No-surprises</em> reporting.</h2>
    </div>
    <div class="tw-reasons-grid">
      {items.map(it => (
        <div class="tw-reason">
          <div class="tw-reason-num">{it.n}</div>
          <h3 class="tw-reason-title">{it.title}</h3>
          <p class="tw-reason-body">{it.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
