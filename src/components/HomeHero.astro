---
---
<section class="tw-home-hero">
  <div class="tw-hero-bg">
    <img src="/assets/hero-aerial.jpg" alt="Aerial view of a Mid-Atlantic community managed by Tidewater" />
  </div>
  <div class="tw-hero-paper" aria-hidden="true"></div>

  <div class="tw-home-hero-inner">
    <div class="tw-home-hero-eyebrow-row">
      <div class="tw-divider"></div>
      <div class="tw-eyebrow">Family-Owned. Community-Focused. Since 1989.</div>
    </div>
    <h1 class="tw-home-hero-title">Hands-On Management for the <em>Mid-Atlantic.</em></h1>
    <p class="tw-home-hero-lede">
      Tidewater Companies is a family-owned management firm serving 400+ HOA, condo, and rental communities across MD, DC, VA, PA, DE, and WV — with the same operational standard we&rsquo;ve held for over 35 years.
    </p>

    <div class="tw-home-hero-paths">
      <a href="/request-a-proposal" class="tw-home-path tw-home-path-primary">
        <div class="tw-home-path-eyebrow">For HOA &amp; Condo Boards</div>
        <div class="tw-home-path-title">Get a free management proposal</div>
        <div class="tw-home-path-sub">One-business-day callback from our management team.</div>
        <div class="tw-home-path-cta">
          Request a proposal
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
        </div>
      </a>
      <a href="https://tidewater.cincwebaxis.com" target="_blank" rel="noopener" class="tw-home-path tw-home-path-secondary">
        <div class="tw-home-path-eyebrow">For Homeowners</div>
        <div class="tw-home-path-title">Owner portal &amp; quick actions</div>
        <div class="tw-home-path-sub">Pay your assessment, submit a request, or log in to your community portal.</div>
        <div class="tw-home-path-cta">
          Owner login
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
        </div>
      </a>
    </div>

    <div class="tw-home-hero-trust">
      <div class="tw-home-hero-trust-item"><span class="accent">400+</span> Communities</div>
      <div class="tw-home-hero-trust-item"><span class="accent">40,000+</span> Homes Managed</div>
      <div class="tw-home-hero-trust-item"><span class="accent">35+</span> Years Independent</div>
      <div class="tw-home-hero-trust-item"><span class="accent">6</span> States Served</div>
      <div class="tw-home-hero-trust-seal">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 2l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6l8-4z"/><path d="M9 12l2 2 4-4"/></svg>
        AAMC® Accredited
      </div>
    </div>
  </div>
</section>
