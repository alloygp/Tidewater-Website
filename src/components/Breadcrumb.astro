---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
  variant?: 'default' | 'realty' | 'management' | 'maintenance';
}
const { crumbs, variant = 'default' } = Astro.props;

// Always prepend Home
const allCrumbs: Crumb[] = [{ label: 'Home', href: '/' }, ...crumbs];

// NOTE: BreadcrumbList JSON-LD is emitted once per page via `breadcrumbSchema()`
// passed into BaseLayout's `pageSchema` — that version is complete (every
// ListItem has an `item`). This component is presentation only; emitting a
// second (incomplete) BreadcrumbList here tripped Google's "Missing field item".
---

<nav class={`tw-breadcrumb${variant === 'realty' ? ' tw-breadcrumb-realty' : variant === 'management' ? ' tw-breadcrumb-management' : variant === 'maintenance' ? ' tw-breadcrumb-maintenance' : ''}`} aria-label="Breadcrumb">
  <div class="tw-breadcrumb-inner">
    <ol class="tw-breadcrumb-list">
      {allCrumbs.map((crumb, i) => {
        const isLast = i === allCrumbs.length - 1;
        return (
          <li class="tw-breadcrumb-item">
            {crumb.href && !isLast ? (
              <a href={crumb.href} class="tw-breadcrumb-link">{crumb.label}</a>
            ) : (
              <span class="tw-breadcrumb-current" aria-current="page">{crumb.label}</span>
            )}
            {!isLast && <span class="tw-breadcrumb-sep" aria-hidden="true">›</span>}
          </li>
        );
      })}
    </ol>
  </div>
</nav>

<style>
  .tw-breadcrumb {
    background: var(--tw-linen, #f5f2eb);
    border-bottom: 1px solid var(--tw-border, rgba(23,35,37,0.10));
  }
  .tw-breadcrumb-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .tw-breadcrumb-list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 10px 0;
  }
  .tw-breadcrumb-item {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .tw-breadcrumb-link {
    font-family: var(--tw-font-body);
    font-size: 12.5px;
    font-weight: 500;
    color: var(--tw-fg-muted, #687070);
    text-decoration: none;
    transition: color .15s ease;
  }
  .tw-breadcrumb-link:hover {
    color: var(--tw-teal, #3a92a6);
  }
  .tw-breadcrumb-current {
    font-family: var(--tw-font-body);
    font-size: 12.5px;
    font-weight: 600;
    color: var(--tw-dark, #172325);
  }
  .tw-breadcrumb-sep {
    font-size: 12px;
    color: var(--tw-fg-subtle, #9eaaaa);
    line-height: 1;
    margin: 0 1px;
  }
  .tw-breadcrumb-realty {
    background: #f9f5e8;
    border-bottom-color: rgba(191,172,95,0.25);
  }
  .tw-breadcrumb-realty .tw-breadcrumb-current { color: #8a7a3d; }
  .tw-breadcrumb-realty .tw-breadcrumb-link:hover { color: #BFAC5F; }

  .tw-breadcrumb-management {
    background: #edf5f7;
    border-bottom-color: rgba(58,146,166,0.2);
  }
  .tw-breadcrumb-management .tw-breadcrumb-current { color: #2F7C8E; }
  .tw-breadcrumb-management .tw-breadcrumb-link:hover { color: #3A92A6; }

  .tw-breadcrumb-maintenance {
    background: #f0f4ee;
    border-bottom-color: rgba(100,125,87,0.2);
  }
  .tw-breadcrumb-maintenance .tw-breadcrumb-current { color: #4a5e3d; }
  .tw-breadcrumb-maintenance .tw-breadcrumb-link:hover { color: #647D57; }
  @media (max-width: 820px) {
    .tw-breadcrumb-inner { padding: 0 20px; }
  }
</style>
