---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;

// Always prepend Home
const allCrumbs: Crumb[] = [{ label: 'Home', href: '/' }, ...crumbs];

// JSON-LD BreadcrumbList for SEO
const schemaItems = allCrumbs.map((c, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  name: c.label,
  ...(c.href ? { item: `https://tidewaterproperty.com${c.href}` } : {}),
}));
const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: schemaItems,
});
---

<nav class="tw-breadcrumb" aria-label="Breadcrumb">
  <div class="tw-breadcrumb-inner">
    <ol class="tw-breadcrumb-list" itemscope itemtype="https://schema.org/BreadcrumbList">
      {allCrumbs.map((crumb, i) => {
        const isLast = i === allCrumbs.length - 1;
        return (
          <li
            class="tw-breadcrumb-item"
            itemprop="itemListElement"
            itemscope
            itemtype="https://schema.org/ListItem"
          >
            {crumb.href && !isLast ? (
              <a href={crumb.href} class="tw-breadcrumb-link" itemprop="item">
                <span itemprop="name">{crumb.label}</span>
              </a>
            ) : (
              <span class="tw-breadcrumb-current" itemprop="name" aria-current="page">{crumb.label}</span>
            )}
            <meta itemprop="position" content={String(i + 1)} />
            {!isLast && <span class="tw-breadcrumb-sep" aria-hidden="true">›</span>}
          </li>
        );
      })}
    </ol>
  </div>
</nav>

<script type="application/ld+json" set:html={schema}></script>

<style>
  .tw-breadcrumb {
    background: var(--tw-linen, #f5f2eb);
    border-bottom: 1px solid var(--tw-border, rgba(23,35,37,0.10));
  }
  .tw-breadcrumb-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .tw-breadcrumb-list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 10px 0;
  }
  .tw-breadcrumb-item {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .tw-breadcrumb-link {
    font-family: var(--tw-font-body);
    font-size: 12.5px;
    font-weight: 500;
    color: var(--tw-fg-muted, #687070);
    text-decoration: none;
    transition: color .15s ease;
  }
  .tw-breadcrumb-link:hover {
    color: var(--tw-teal, #3a92a6);
  }
  .tw-breadcrumb-current {
    font-family: var(--tw-font-body);
    font-size: 12.5px;
    font-weight: 600;
    color: var(--tw-dark, #172325);
  }
  .tw-breadcrumb-sep {
    font-size: 12px;
    color: var(--tw-fg-subtle, #9eaaaa);
    line-height: 1;
    margin: 0 1px;
  }
  @media (max-width: 820px) {
    .tw-breadcrumb-inner { padding: 0 20px; }
  }
</style>
