---
---
<section class="tw-hero">
  <div class="tw-hero-bg">
    <img src="/assets/hero-mission.jpg" alt="A Maryland rental property" />
  </div>
  <div class="tw-hero-paper" aria-hidden="true"></div>

  <div class="tw-hero-grid">
    <div class="tw-hero-copy">
      <div class="tw-hero-eyebrow-row">
        <div class="tw-divider"></div>
        <div class="tw-eyebrow">For Maryland &amp; Delaware Landlords</div>
      </div>
      <h1 class="tw-hero-title">One flat fee. Everything included. <em>Down to the inspection.</em></h1>
      <p class="tw-hero-lede">Most rental management companies advertise a low monthly rate &mdash; then bill you for every property visit, every inspection, every coordination call. Tidewater doesn&rsquo;t. One transparent percentage. Routine services all-in &mdash; some add-ons available with an addendum.</p>
      <div class="tw-hero-actions">
        <a href="#contact" class="tw-btn tw-btn-primary tw-btn-lg">Get a rental market analysis</a>
        <a href="#fee" class="tw-btn tw-btn-ghost">See what&rsquo;s included &rarr;</a>
        <a href="#listings" class="tw-btn tw-btn-ghost">See open listings &darr;</a>
      </div>
      <div class="tw-hero-trust tw-hero-trust-rental" style="display:grid;grid-template-columns:1fr 1fr;gap:12px 24px">
        <div class="tw-hero-trust-item"><div class="tw-hero-trust-num"><span class="accent">Bi-annual</span></div><div class="tw-hero-trust-label">Inspections</div></div>
        <div class="tw-hero-trust-item"><div class="tw-hero-trust-num"><span class="accent">3&ndash;5 days</span></div><div class="tw-hero-trust-label">Application turnaround</div></div>
        <div class="tw-hero-trust-item"><div class="tw-hero-trust-num"><span class="accent">20 min</span></div><div class="tw-hero-trust-label">Emergency response</div></div>
        <div class="tw-hero-trust-item"><div class="tw-hero-trust-num"><span class="accent">35+ yrs</span></div><div class="tw-hero-trust-label">In property mgmt</div></div>
      </div>
    </div>

    <div class="tw-hero-side">
      <div class="tw-rh-card">
        <div class="tw-rh-card-head">
          <div class="tw-rh-card-eyebrow"><span class="tw-rh-card-dot"></span>What &ldquo;all-inclusive&rdquo; really means</div>
          <div class="tw-rh-card-badge">FLAT FEE</div>
        </div>
        <h3 class="tw-rh-card-title">A side-by-side from a real owner&rsquo;s statement</h3>
        <div class="tw-rh-compare-grid">
          <div class="tw-rh-compare-col tw-rh-compare-them">
            <div class="tw-rh-compare-head">Low-fee competitor</div>
            <ul class="tw-rh-compare-list">
              <li><span class="tw-rh-line">Base mgmt fee</span><span class="tw-rh-amt">7%</span></li>
              <li><span class="tw-rh-line">+ Property visits</span><span class="tw-rh-amt">$95 ea</span></li>
              <li><span class="tw-rh-line">+ Maint. coordination</span><span class="tw-rh-amt">10%</span></li>
              <li><span class="tw-rh-line">+ Annual inspection</span><span class="tw-rh-amt">$185</span></li>
              <li><span class="tw-rh-line">+ Lease renewal</span><span class="tw-rh-amt">$295</span></li>
            </ul>
          </div>
          <div class="tw-rh-compare-col tw-rh-compare-us">
            <div class="tw-rh-compare-head">Tidewater</div>
            <ul class="tw-rh-compare-list">
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg><span>Base mgmt fee</span></li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg><span>Licensing management</span></li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg><span>Maint. coordination</span></li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg><span>Bi-annual inspections</span></li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg><span>Lease renewals</span></li>
            </ul>
          </div>
        </div>
        <div class="tw-rh-card-foot">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 2l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6l8-4z"/><path d="M9 12l2 2 4-4"/></svg>
          <span><strong>One flat percentage.</strong> That&rsquo;s the whole bill.</span>
        </div>
      </div>
    </div>
  </div>

  <div class="tw-hero-scroll">
    <div class="tw-hero-scroll-line"></div>
    Why landlords switch <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
  </div>
</section>
