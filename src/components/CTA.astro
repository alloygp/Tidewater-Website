---
const {
  eyebrow = 'Request a Proposal',
  title = "Let\'s talk about your community.",
  body = 'Tell us a little about your association and a manager from your region will be in touch within one business day.',
} = Astro.props;
---
<section class="tw-cta" id="contact">
  <div class="tw-cta-inner">
    <div>
      <div class="tw-eyebrow">{eyebrow}</div>
      <h2 class="tw-cta-title">{title}</h2>
      <p class="tw-cta-body">{body}</p>
      <ul class="tw-cta-points">
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>One-business-day response from a regional manager</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Free, no-obligation proposal &amp; transition timeline</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Transparent pricing breakdown with no setup or exit fees</li>
      </ul>
    </div>
    <form class="tw-cta-form" id="proposal-form">
      <!-- Honeypot — hidden from real users, bots fill it in -->
      <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0" />
      <div>
        <h3 class="tw-cta-form-title">Get a proposal</h3>
        <p class="tw-cta-form-sub">All fields are required. We&rsquo;ll never share your information.</p>
      </div>
      <div class="tw-row-2">
        <div class="tw-field"><label>First name</label><input name="firstName" placeholder="Marcia" /></div>
        <div class="tw-field"><label>Last name</label><input name="lastName" placeholder="Sullivan" /></div>
      </div>
      <div class="tw-field"><label>Board email</label><input type="email" name="email" placeholder="treasurer@yourcommunity.org" /></div>
      <div class="tw-row-2">
        <div class="tw-field"><label>Community name</label><input name="community" placeholder="Wynbrook HOA" /></div>
        <div class="tw-field">
          <label>Number of homes</label>
          <select name="communitySize">
            <option value="" disabled selected>Select…</option>
            <option>Under 50</option>
            <option>50–150</option>
            <option>150–500</option>
            <option>500+</option>
          </select>
        </div>
      </div>
      <div class="tw-field">
        <label>Service interest</label>
        <select name="serviceInterest">
          <option value="full">Full Service Management</option>
          <option>Flex Service</option>
          <option>Financial Only</option>
          <option>Developer Program</option>
          <option>Not sure yet — I&rsquo;d like to talk it through</option>
        </select>
      </div>
      <button class="tw-btn tw-btn-primary tw-btn-block tw-btn-lg" type="submit">Request my proposal</button>
      <p class="tw-field-fine">Or call <strong>(443) 548-0191</strong> · 24/7 emergency line for current communities</p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('proposal-form');
  const btn = form?.querySelector('button[type="submit"]');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
    const fd = new FormData(form);
    // Combine first + last into name
    const first = fd.get('firstName') || '';
    const last  = fd.get('lastName')  || '';
    fd.set('name', `${first} ${last}`.trim());
    fd.set('company', fd.get('community') || '');
    try {
      const res = await fetch('/api/lead', { method: 'POST', body: fd });
      const json = await res.json();
      if (!res.ok) throw new Error(json.error);
      form.innerHTML = '<div style="padding:32px;text-align:center;font-family:var(--tw-font-heading);font-weight:700;font-size:18px">Thanks — we\'ll be in touch within one business day.</div>';
    } catch (err) {
      if (btn) { btn.disabled = false; btn.textContent = 'Request my proposal'; }
      alert(err.message || 'Something went wrong. Please try again.');
    }
  });
</script>
