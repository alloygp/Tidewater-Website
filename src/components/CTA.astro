---
const {
  variant   = 'hoa',
  eyebrow   = variant === 'rental' ? 'Talk to Our Rental Team'
            : variant === 'realty' ? 'Talk to an Agent'
            : 'Request a Proposal',
  title     = variant === 'rental' ? "Let's talk about your rental property."
            : variant === 'realty' ? "Let's talk about your property goals."
            : "Let's talk about your community.",
  body      = variant === 'rental'
            ? 'Whether you&rsquo;re managing from out of state or looking for your first property manager &mdash; our rental team will be in touch within one business day.'
            : variant === 'realty'
            ? 'Whether you&rsquo;re buying, selling, or investing in Maryland or Delaware &mdash; a licensed Tidewater agent will be in touch within one business day.'
            : 'Tell us a little about your association and a manager from your region will be in touch within one business day.',
} = Astro.props;

const isRental = variant === 'rental';
const isRealty = variant === 'realty';
---
<section class="tw-cta" id="contact">
  <div class="tw-cta-inner">
    <div>
      <div class="tw-eyebrow">{eyebrow}</div>
      <h2 class="tw-cta-title">{title}</h2>
      <p class="tw-cta-body" set:html={body} />
      <ul class="tw-cta-points">
        {isRental ? (
          <>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Same or next business day response from our rental team</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Free rental market analysis &mdash; no obligation</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Own a home in a Tidewater-managed community? A management discount may apply.</li>
          </>
        ) : isRealty ? (
          <>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Same or next business day response from a licensed agent</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Free market analysis &mdash; buyer, seller, or investor</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Selling in a Tidewater-managed community? Ask about our listing discount.</li>
          </>
        ) : (
          <>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Same or next business day response from our team</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Free, no-obligation proposal &amp; transition timeline</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Transparent pricing &mdash; all fees disclosed upfront</li>
          </>
        )}
      </ul>
    </div>
    <div class="tw-cta-form tw-cta-card">
      <h3 class="tw-cta-form-title">{isRental ? 'Get a rental market analysis' : isRealty ? 'Talk to an agent' : 'Get your proposal'}</h3>
      <p class="tw-cta-form-sub">Tell us a little about your {isRental ? 'property' : isRealty ? 'goals' : 'community'} and the right person will be in touch within one business day. No pressure, ever.</p>
      <a href={isRealty ? '/request-a-proposal#contact-form' : isRental ? '/request-a-proposal?intent=rental#contact-form' : '/request-a-proposal?intent=proposal#contact-form'} class="tw-btn tw-btn-primary tw-btn-block tw-btn-lg">Request Proposal / Contact &rarr;</a>
      <p class="tw-field-fine">Prefer to call? <strong>(443) 548-0191</strong>{isRental ? ' · 24/7 emergency line for current owners' : isRealty ? ' · One business day response' : ' · 24/7 emergency line for current communities'}</p>
    </div>
  </div>
</section>
