---
---
<section class="tw-section tw-section-dark" id="portal" style="padding:112px 0">
  <div class="tw-container">
    <div class="tw-portal-grid">
      <div class="tw-portal-copy">
        <div class="tw-eyebrow tw-eyebrow-gold">Built On CINC Systems</div>
        <h2 class="tw-section-title tw-section-title-light">
          A board portal you&rsquo;ll actually use. <em class="gold">An AI assistant named after our founder.</em>
        </h2>
        <p class="tw-section-lede" style="color:#cfcdc6">
          Boards see the full operational picture in real time &mdash; violation tracking, ARC requests, delinquencies, action items, and management reports. Owners get 24/7 access on every device. The Tidewater PM app puts it all in one place.
        </p>
        <ul class="tw-portal-features">
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Real-time violation &amp; compliance monitoring</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Live management plan status &amp; action items</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>ARC request tracking &amp; resident communications</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Optional StrongRoom invoice approval for boards</li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span><strong style="color:var(--tw-gold)">Stanley</strong> &mdash; AI assistant, named for our founder, available to every owner</span>
          </li>
        </ul>

        <a href="https://tidewater.cincwebaxis.com" target="_blank" rel="noopener" class="tw-portal-app-tile">
          <div class="tw-portal-app-tile-content">
            <div class="tw-portal-app-tile-title">Download Tidewater App</div>
            <div class="tw-portal-app-tile-sub">Owner &amp; board portal on every device</div>
          </div>
          <div class="tw-portal-app-tile-badges">
            <span class="tw-portal-app-badge">
              <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              App Store
            </span>
            <span class="tw-portal-app-badge">
              <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M3.18 23.76c.3.17.64.22.98.16l12.29-7.08-2.79-2.79-10.48 9.71zm-1.7-20.4C1.18 3.7 1 4.08 1 4.56v14.88c0 .48.18.86.48 1.2l.07.06 8.34-8.34v-.2L1.55 3.3l-.07.06zM19.7 10.4l-2.68-1.55-3.07 3.07 3.07 3.07 2.7-1.55c.77-.44.77-1.6-.02-2.04zM4.18.24L16.47 7.3l-2.79 2.79L3.2.38c.34-.06.68-.01.98.17v-.31z"/></svg>
              Google Play
            </span>
          </div>
        </a>
      </div>

      <div class="tw-portal-mock">
        <div class="tw-portal-mock-bar">
          <div class="tw-portal-mock-bar-dot" style="background:#FF6B5C"></div>
          <div class="tw-portal-mock-bar-dot" style="background:#FFBD3D"></div>
          <div class="tw-portal-mock-bar-dot" style="background:#1FC73E"></div>
          <div class="tw-portal-mock-bar-url">tidewater.cincwebaxis.com / board</div>
        </div>
        <div style="overflow:hidden;border-radius:0 0 10px 10px;line-height:0">
          <img src="/assets/cinc-board-portal.jpg" alt="Tidewater CINC board portal dashboard showing violations, work orders, ACC requests, upcoming meetings, and the Stanley AI assistant" style="width:100%;display:block" />
        </div>
      </div>
    </div>
  </div>
</section>
