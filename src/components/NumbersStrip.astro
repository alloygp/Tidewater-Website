---
const stats = [
  { num: '35+', label: 'Years independent', sub: 'Family-owned since 1989' },
  { num: '300+', label: 'Communities managed', sub: '~50/50 HOA / condo' },
  { num: '30K+', label: 'Homes under management', sub: 'Across 6 states' },
  { num: '~75', label: 'In-house team', sub: 'No outsourced functions' },
  { num: '2', label: 'CAI Chapter Presidents', sub: 'On staff today' },
  { num: '5–15 yr', label: 'Employee tenure', sub: 'Industry avg is ~2 years' },
];
---
<section class="tw-numstrip">
  <div class="tw-container">
    <div class="tw-numstrip-grid">
      {stats.map((s) => (
        <div class="tw-numstrip-cell">
          <div class="tw-numstrip-num">{s.num}</div>
          <div class="tw-numstrip-label">{s.label}</div>
          <div class="tw-numstrip-sub">{s.sub}</div>
        </div>
      ))}
    </div>
  </div>
</section>
