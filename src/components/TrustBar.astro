---
const { variant = 'hoa' } = Astro.props;

const hoaItems = [
  { icon: 'AAMC', label: 'AAMC® Accredited',          sub: "CAI's highest company credential",     cls: '' },
  { icon: 'PCAM', label: 'PCAM Leadership',            sub: 'President holds CMCA, AMS, PCAM',     cls: 'tw-trust-icon-gold' },
  { icon: 'CAI',  label: 'Two CAI Chapter Presidents', sub: 'Chesapeake Chapter leaders',           cls: 'tw-trust-icon-sage' },
  { icon: 'A+',   label: 'A+ BBB Rating',              sub: 'Backed by 35+ years of work',         cls: 'tw-trust-icon-clay' },
];

const rentalItems = [
  { icon: 'NAR',   label: 'NARPM Member',              sub: 'National Assoc. of Residential Property Managers', cls: '' },
  { icon: 'APP',   label: 'AppFolio Powered',          sub: 'Owner portal, tenant portal, and maintenance', cls: 'tw-trust-icon-gold' },
  { icon: 'A+',    label: 'A+ BBB Rating',             sub: 'Backed by 35+ years of work',         cls: 'tw-trust-icon-sage' },
  { icon: 'LIC',   label: 'Licensed Broker',           sub: 'Maryland & Delaware, active licenses', cls: 'tw-trust-icon-clay' },
];

const realtyItems = [
  { icon: 'R®',    label: 'REALTOR®',                  sub: 'NAR member — Tidewater Realty Group',  cls: '' },
  { icon: 'EHO',   label: 'Equal Housing Opportunity', sub: 'Fair housing in every transaction',   cls: 'tw-trust-icon-gold' },
  { icon: 'A+',    label: 'A+ BBB Rating',             sub: 'Backed by 35+ years of work',         cls: 'tw-trust-icon-sage' },
  { icon: 'LIC',   label: 'Licensed: MD + DE',         sub: 'Active brokerage licenses, both states', cls: 'tw-trust-icon-clay' },
];

const items = variant === 'rental' ? rentalItems : variant === 'realty' ? realtyItems : hoaItems;
---
<section class="tw-trust-bar" aria-label="Credentials and accreditations">
  <div class="tw-trust-inner">
    <div class="tw-trust-label">Trusted &amp; credentialed by</div>
    <div class="tw-trust-items">
      {items.map(it => (
        <div class="tw-trust-item">
          <div class={`tw-trust-icon ${it.cls}`}>{it.icon}</div>
          <div class="tw-trust-item-text">
            <div>{it.label}</div>
            <div class="tw-trust-item-sub">{it.sub}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
