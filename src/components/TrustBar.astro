---
const items = [
  { icon: 'AAMC', label: 'AAMC® Accredited',        sub: "CAI\'s highest company credential",        cls: '' },
  { icon: 'PCAM', label: 'PCAM Leadership',          sub: 'President holds CMCA, AMS, PCAM',        cls: 'tw-trust-icon-gold' },
  { icon: 'CAI',  label: 'Two CAI Chapter Presidents', sub: 'Chesapeake Chapter leaders',            cls: 'tw-trust-icon-sage' },
  { icon: 'A+',   label: 'A+ BBB Rating',            sub: 'Backed by 35+ years of work',            cls: 'tw-trust-icon-clay' },
];
---
<section class="tw-trust-bar" aria-label="Credentials and accreditations">
  <div class="tw-trust-inner">
    <div class="tw-trust-label">Trusted &amp; credentialed by</div>
    <div class="tw-trust-items">
      {items.map(it => (
        <div class="tw-trust-item">
          <div class={`tw-trust-icon ${it.cls}`}>{it.icon}</div>
          <div class="tw-trust-item-text">
            <div>{it.label}</div>
            <div class="tw-trust-item-sub">{it.sub}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
