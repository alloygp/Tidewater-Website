<section class="tw-owner-actions" id="owner">
  <div class="tw-container-wide">
    <div class="tw-owner-actions-head">
      <div>
        <div class="tw-eyebrow">For Homeowners in Tidewater-Managed Communities</div>
        <h2 class="tw-owner-actions-title">Quick actions for residents.</h2>
      </div>
      <a href="/request-a-proposal" class="tw-btn tw-btn-outline">Visit the help center →</a>
    </div>
    <div class="tw-owner-actions-grid">
      <a href="https://tidewater.cincwebaxis.com" target="_blank" rel="noopener" class="tw-owner-action">
        <div class="tw-owner-action-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></div>
        <div class="tw-owner-action-title">Pay Assessment</div>
        <div class="tw-owner-action-sub">Online via the owner portal</div>
      </a>
      <a href="https://tidewater.cincwebaxis.com" target="_blank" rel="noopener" class="tw-owner-action">
        <div class="tw-owner-action-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a4 4 0 0 1-5.4 5.4L4 17v3h3l5.3-5.3a4 4 0 0 1 5.4-5.4l-3 3-2-2 3-3z"/></svg></div>
        <div class="tw-owner-action-title">Submit a Request</div>
        <div class="tw-owner-action-sub">Maintenance, ARC, violations</div>
      </a>
      <a href="https://tidewater.cincwebaxis.com" target="_blank" rel="noopener" class="tw-owner-action">
        <div class="tw-owner-action-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
