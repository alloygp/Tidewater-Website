          <!-- Col 3: Condo pillar (standalone) -->
          <div class="tw-mega-col">
            <div class="tw-mega-col-label">Condo Management</div>
            <div class="tw-mega-list">
              <a href="/condo-management" class="tw-mega-item">
                <div class="tw-mega-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="3" width="16" height="18" rx="1"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/><line x1="9" y1="13" x2="9.01" y2="13"/><line x1="15" y1="13" x2="15.01" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg></div>
                <div><div class="tw-mega-title">Condo Association Management</div><div class="tw-mega-body">High-rise, mid-rise, and garden-style expertise.</div></div>
              </a>
              <a href="/hoa-management/commercial-association-management" class="tw-mega-item">
                <div class="tw-mega-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="2" y1="21" x2="22" y2="21"/><rect x="5" y="8" width="6" height="13"/><rect x="13" y="3" width="6" height="18"/></svg></div>
                <div><div class="tw-mega-title">Commercial Associations</div><div class="tw-mega-body">Mixed-use, office condos, and business parks.</div></div>
              </a>
            </div>
          </div>

          <!-- Col 4: Rental pillar -->
          <div class="tw-mega-col">
            <div class="tw-mega-col-label">Rental Management</div>
            <div class="tw-mega-list">
              <a href="/rental-management" class="tw-mega-item">
                <div class="tw-mega-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
                <div><div class="tw-mega-title">Rental Property Management</div><div class="tw-mega-body">For owners. One flat fee, single-family &amp; multifamily.</div></div>
              </a>
              <a href="/rental-listings" class="tw-mega-item">
                <div class="tw-mega-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="21" x2="21" y2="21"/><path d="M6 21V4a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v17"/><circle cx="14.5" cy="12" r="1"/></svg></div>
                <div><div class="tw-mega-title">Available Rentals</div><div class="tw-mega-body">For renters. Browse homes available now &amp; apply online.</div></div>
              </a>
            </div>
