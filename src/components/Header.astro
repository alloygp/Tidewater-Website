                <div class="tw-mega-solcard-overlay"></div>
                <div class="tw-mega-solcard-body">
                  <div class="tw-mega-solcard-eyebrow">Self-managed today?</div>
                  <div class="tw-mega-solcard-title">Self-Managed Transition</div>
                  <div class="tw-mega-solcard-cta">See how it works →</div>
