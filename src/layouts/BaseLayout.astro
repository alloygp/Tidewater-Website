---
interface Props {
  title: string;
  description: string;
  bodyClass?: string;
  pageStylesheet?: string;
}
const { title, description, bodyClass = '', pageStylesheet } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="stylesheet" href="/styles.css" />
  {pageStylesheet && <link rel="stylesheet" href={`/${pageStylesheet}`} />}
  <slot name="head" />
</head>
<body class={bodyClass}>
  <slot />
</body>
</html>
