---
// src/layouts/BaseLayout.astro
// Root layout for all non-about pages. SEO pulled from src/config/site.ts.
//
// Usage (minimal):
//   <BaseLayout title="Page Title" description="Meta description.">…</BaseLayout>
//
// Usage (service page with schema):
//   <BaseLayout title="…" description="…" pageSchema={[serviceSchema, breadcrumbSchema]}>
//
// Usage (noindex):
//   <BaseLayout title="…" description="…" robots="noindex,nofollow">

import { SITE } from '../config/site';

interface Props {
  /** <title> tag. Required. */
  title: string;
  /** Meta description. 120–160 chars. Required. */
  description: string;
  /** Body class(es) for accent colour variants. */
  bodyClass?: string;
  /** Additional stylesheet to load (e.g. 'styles-pages.css'). */
  pageStylesheet?: string;
  /** og:type — 'website' for service/info pages, 'article' for blog/resource pages. */
  ogType?: 'website' | 'article';
  /** Per-page OG image. Absolute path from /public. Defaults to SITE.defaultOgImage. */
  ogImage?: string;
  /** robots meta content. Omit for normal indexed pages. Use "noindex,nofollow" for staging/legal. */
  robots?: string;
  /** Page-specific JSON-LD. Pass a single object or an array from src/lib/schema.ts. */
  pageSchema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  bodyClass = '',
  pageStylesheet,
  ogType = 'website',
  ogImage: ogImageProp,
  robots: robotsProp,
  pageSchema,
} = Astro.props;

// Auto-noindex on any environment that hasn\'t explicitly set PUBLIC_ENV=production.
// In Vercel: set PUBLIC_ENV=production on the production project only.
// Staging / preview deployments will get noindex (not nofollow — nofollow breaks crawlers like Screaming Frog).
const isProduction = import.meta.env.PUBLIC_ENV === 'production';
const robots = robotsProp ?? (isProduction ? undefined : 'noindex');

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? SITE.url).toString();

const resolvedOgImage = new URL(
  ogImageProp ?? SITE.defaultOgImage,
  Astro.site ?? SITE.url
).toString();

const orgLd = {
  '@context': 'https://schema.org',
  '@type': SITE.org.type,
  name: SITE.name,
  url: SITE.url,
  logo: SITE.org.logo,
  description,
  address: {
    '@type': 'PostalAddress',
    addressLocality: SITE.org.addressLocality,
    addressRegion: SITE.org.addressRegion,
    addressCountry: SITE.org.addressCountry,
  },
  telephone: SITE.org.telephone,
  email: SITE.org.email,
  areaServed: SITE.org.areaServed,
  priceRange: SITE.org.priceRange,
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/png" href="/assets/favicon.png" />

  <!-- Robots (only emitted when explicitly set) -->
  {robots && <meta name="robots" content={robots} />}

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:locale" content={SITE.locale} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content={SITE.ogImageWidth} />
  <meta property="og:image:height" content={SITE.ogImageHeight} />
  <meta property="og:image:alt" content={SITE.name} />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content={SITE.twitterHandle} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />
  <meta name="twitter:image:alt" content={SITE.name} />

  <!-- Stylesheets -->
  <link rel="stylesheet" href="/styles.css" />
  {pageStylesheet && <link rel="stylesheet" href={`/${pageStylesheet}`} />}

  <!-- JSON-LD: Organization (every page) -->
  <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />

  <!-- JSON-LD: Page-specific schema (optional) -->
  {pageSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
  )}

  <slot name="head" />
</head>
<body class={bodyClass}>
  <slot />
</body>
</html>
