---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Header from '../components/Header.astro';
import RealtyHero from '../components/RealtyHero.astro';
import TrustBar from '../components/TrustBar.astro';
import RealtyLifecycle from '../components/RealtyLifecycle.astro';
import RealtyServices from '../components/RealtyServices.astro';
import RealtyInsider from '../components/RealtyInsider.astro';
import Mission from '../components/Mission.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---
<BaseLayout
  title="Tidewater Realty Group — Your Guide in Buying & Selling Investment Property"
  description="Family-owned brokerage covering Maryland & DC."
  bodyClass="tw-acc-gold"
  pageStylesheet="styles-pages.css"
>
  <Topbar variant="homeowner" />
  <Header activeNav="realty" />
  <Breadcrumb crumbs={[{ label: "Real Estate" }]} />
  <RealtyHero />
  <TrustBar />
  <RealtyLifecycle />
  <RealtyServices />
  <RealtyInsider />
  <Mission />
  <Testimonials />
  <CTA />
  <Footer />
</BaseLayout>
