---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Header from '../components/Header.astro';
import RealtyHero from '../components/RealtyHero.astro';
import TrustBar from '../components/TrustBar.astro';
import RealtyLifecycle from '../components/RealtyLifecycle.astro';
import RealtyServices from '../components/RealtyServices.astro';
import RealtyInsider from '../components/RealtyInsider.astro';
import Mission from '../components/Mission.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FromTheBlog from '../components/FromTheBlog.jsx';
import { serviceSchema, breadcrumbSchema } from '../lib/schema';
import { SITE } from '../config/site';

const pageUrl = `${SITE.url}/real-estate`;
const pageDesc = "Family-owned brokerage covering Maryland & Delaware. Buying, selling, and investing in residential and investment properties.";

const schemas = [
  serviceSchema({ name: 'Tidewater Realty Group — Real Estate Services', description: pageDesc, url: pageUrl, areaServed: ['Maryland', 'Delaware'] }),
  breadcrumbSchema([{ name: 'Home', url: SITE.url + '/' }, { name: 'Real Estate', url: pageUrl }]),
];
---
<BaseLayout
  title="Buy & Sell Investment Property | Tidewater Realty"
  description={pageDesc}
  bodyClass="tw-acc-gold"
  pageStylesheet="styles-pages.css"
  pageSchema={schemas}
>
  <Topbar variant="homeowner" />
  <Header activeNav="realty" />
  <Breadcrumb crumbs={[{ label: "Real Estate" }]} />
  <RealtyHero />
  <TrustBar variant="realty" />
  <RealtyLifecycle />
  <RealtyServices />
  <RealtyInsider />
  <Mission variant="realty" />
  <!-- PLACEHOLDER: Real estate buyer/seller testimonials needed here.
       Replace with quotes from actual Tidewater Realty Group clients — buyers, sellers, or investors.
       Do not use HOA board member testimonials on this page. -->
  <section style="border:2px dashed #e8a838;background:#fffbf0;padding:28px 32px;text-align:center">
    <p style="font-family:monospace;font-size:13px;color:#7a5e1d;margin:0">
      ⚠️ <strong>PLACEHOLDER — Real Estate Testimonials</strong><br/>
      Replace with: buyer, seller, or investor testimonials from Tidewater Realty Group clients.<br/>
      <em>HOA board testimonials removed — not relevant to real estate buyers and sellers.</em>
    </p>
  </section>
  <FromTheBlog client:load categories={['rental', 'solutions']} />
  <CTA variant="realty" />
  <Footer />
</BaseLayout>
