---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Page Not Found — Tidewater Companies"
  description="The page you were looking for has drifted off the map. Find your way back to Tidewater Companies — HOA, condo, and rental property management for the Mid-Atlantic."
>
  <style>
    /* ============= 404 specific ============= */
    .tw-404 {
      position: relative;
      background: var(--tw-dark);
      color: var(--tw-cream);
      overflow: hidden;
      isolation: isolate;
    }
    .tw-404-bg {
      position: absolute; inset: 0; z-index: 0;
      background:
        radial-gradient(ellipse at 18% 30%, rgba(58,146,166,0.30) 0%, transparent 55%),
        radial-gradient(ellipse at 85% 75%, rgba(191,172,95,0.14) 0%, transparent 50%),
        var(--tw-dark);
    }
    .tw-404-paper {
      position: absolute; inset: 0; pointer-events: none; z-index: 1;
      background-image:
        url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='2.4' numOctaves='1' stitchTiles='stitch' seed='4'/><feColorMatrix values='0 0 0 0 0.30  0 0 0 0 0.22  0 0 0 0 0.12  0 0 0 1.6 -0.4'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
      background-size: 160px 160px;
      mix-blend-mode: screen;
      opacity: 0.20;
    }
    .tw-404-vignette {
      position: absolute; inset: 0; pointer-events: none; z-index: 2;
      background: radial-gradient(ellipse 100% 80% at 50% 50%, transparent 50%, rgba(0,0,0,0.45) 100%);
    }

    .tw-404-grid {
      position: relative; z-index: 5;
      max-width: 1320px; margin: 0 auto;
      padding: 96px 32px 110px;
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 80px;
      align-items: center;
      min-height: 720px;
    }

    /* ----- left: numeral + copy ----- */
    .tw-404-eyebrow-row { display: flex; align-items: center; gap: 14px; margin-bottom: 22px; }
    .tw-404-eyebrow-row .tw-divider { width: 36px; height: 2px; background: var(--tw-gold); }
    .tw-404-eyebrow-row .tw-eyebrow { color: var(--tw-gold); }

    .tw-404-numeral {
      font-family: var(--tw-font-heading);
      font-weight: 900;
      font-size: clamp(180px, 22vw, 320px);
      line-height: 0.88;
      letter-spacing: -0.06em;
      color: transparent;
      -webkit-text-stroke: 2px rgba(254,252,248,0.18);
      margin: 0 0 12px;
      position: relative;
      display: inline-block;
    }
    .tw-404-numeral .filled {
      color: var(--tw-gold);
      -webkit-text-stroke: 0;
      font-style: italic;
      font-weight: 300;
      margin: 0 -0.04em;
    }
    .tw-404-numeral::after {
      content: '';
      position: absolute;
      left: 0; right: 0; bottom: 14%;
      height: 2px;
      background: linear-gradient(90deg, transparent 0%, rgba(191,172,95,0.4) 30%, rgba(191,172,95,0.4) 70%, transparent 100%);
      opacity: 0.6;
    }

    .tw-404-title {
      font-family: var(--tw-font-heading);
      font-weight: 800;
      font-size: clamp(36px, 4.0vw, 56px);
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--tw-cream);
      margin: 0 0 22px;
      text-wrap: balance;
      max-width: 620px;
    }
    .tw-404-title em {
      font-style: italic;
      font-weight: 300;
      color: var(--tw-gold);
    }

    .tw-404-lede {
      font-family: var(--tw-font-body);
      font-weight: 400;
      font-size: 18px;
      line-height: 1.65;
      color: rgba(254,252,248,0.78);
      margin: 0 0 32px;
      max-width: 520px;
    }
    .tw-404-lede a { color: var(--tw-gold); text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1px; }
    .tw-404-lede a:hover { color: var(--tw-cream); }

    .tw-404-actions { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; margin-bottom: 40px; }
    .tw-404-actions .tw-btn-ghost { color: var(--tw-cream); }
    .tw-404-actions .tw-btn-ghost:hover { color: var(--tw-gold); }

    .tw-404-search {
      display: flex;
      align-items: center;
      background: rgba(254,252,248,0.06);
      border: 1px solid rgba(254,252,248,0.18);
      border-radius: 999px;
      padding: 6px 6px 6px 20px;
      max-width: 520px;
      transition: border-color .2s ease, background .2s ease;
    }
    .tw-404-search:focus-within {
      border-color: var(--tw-gold);
      background: rgba(254,252,248,0.10);
    }
    .tw-404-search svg { width: 16px; height: 16px; color: rgba(254,252,248,0.55); flex-shrink: 0; }
    .tw-404-search input {
      flex: 1;
      background: transparent;
      border: 0;
      outline: 0;
      color: var(--tw-cream);
      font-family: var(--tw-font-body);
      font-size: 15px;
      padding: 12px 14px;
      min-width: 0;
    }
    .tw-404-search input::placeholder { color: rgba(254,252,248,0.5); }
    .tw-404-search button {
      background: var(--tw-gold);
      color: var(--tw-dark);
      border: 0;
      border-radius: 999px;
      padding: 10px 20px;
      font-family: var(--tw-font-heading);
      font-weight: 700;
      font-size: 13px;
      cursor: pointer;
      transition: background .15s ease;
      white-space: nowrap;
    }
    .tw-404-search button:hover { background: #d4c179; }

    /* ----- right: quick-return panel ----- */
    .tw-404-panel {
      position: relative;
      background: rgba(254,252,248,0.96);
      color: var(--tw-dark);
      border-radius: 14px;
      padding: 32px 32px 28px;
      box-shadow: 0 28px 70px rgba(0,0,0,0.45);
      border: 1px solid rgba(254,252,248,0.4);
    }
    .tw-404-panel-head {
      display: flex; align-items: center; justify-content: space-between;
      gap: 12px; margin-bottom: 22px; padding-bottom: 18px;
      border-bottom: 1px solid var(--tw-border);
    }
    .tw-404-panel-eyebrow {
      font-family: var(--tw-font-heading);
      font-weight: 700; font-size: 10px;
      text-transform: uppercase; letter-spacing: 0.18em;
      color: var(--tw-teal);
      display: inline-flex; align-items: center; gap: 8px;
    }
    .tw-404-panel-eyebrow::before {
      content: '';
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--tw-teal);
    }
    .tw-404-panel-meta {
      font-family: var(--tw-font-mono);
      font-size: 11px;
      color: var(--tw-fg-subtle);
      letter-spacing: 0.04em;
    }

    .tw-404-panel-title {
      font-family: var(--tw-font-heading);
      font-weight: 800;
      font-size: 22px;
      line-height: 1.2;
      color: var(--tw-dark);
      margin: 0 0 6px;
      letter-spacing: -0.01em;
    }
    .tw-404-panel-sub {
      font-family: var(--tw-font-body);
      font-size: 13.5px;
      line-height: 1.55;
      color: var(--tw-fg-muted);
      margin: 0 0 18px;
    }

    .tw-404-links { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 4px; }
    .tw-404-link {
      display: grid;
      grid-template-columns: 40px 1fr auto;
      align-items: center;
      gap: 14px;
      padding: 12px 14px;
      border-radius: 8px;
      text-decoration: none;
      transition: background .15s ease, transform .15s ease;
    }
    .tw-404-link:hover { background: var(--tw-linen); transform: translateX(2px); }
    .tw-404-link:hover .tw-404-link-arrow { color: var(--tw-teal); transform: translateX(2px); }
    .tw-404-link-icon {
      width: 40px; height: 40px;
      border-radius: 8px;
      background: var(--tw-teal-50);
      color: var(--tw-teal);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .tw-404-link-icon svg { width: 18px; height: 18px; }
    .tw-404-link-icon.gold { background: rgba(191,172,95,0.16); color: #8a7a3d; }
    .tw-404-link-icon.sage { background: rgba(100,125,87,0.14); color: var(--tw-sage); }
    .tw-404-link-icon.clay { background: rgba(206,142,114,0.18); color: #9a5a3a; }
    .tw-404-link-text {
      display: flex; flex-direction: column; gap: 2px; min-width: 0;
    }
    .tw-404-link-title {
      font-family: var(--tw-font-heading);
      font-weight: 700; font-size: 14px;
      color: var(--tw-dark); line-height: 1.25;
    }
    .tw-404-link-sub {
      font-family: var(--tw-font-body);
      font-size: 12.5px;
      color: var(--tw-fg-muted); line-height: 1.4;
    }
    .tw-404-link-arrow {
      font-family: var(--tw-font-heading);
      font-size: 16px;
      color: var(--tw-fg-subtle);
      transition: transform .15s ease, color .15s ease;
    }

    .tw-404-panel-foot {
      margin-top: 22px;
      padding-top: 18px;
      border-top: 1px solid var(--tw-border);
      display: flex; align-items: center; gap: 12px;
      font-family: var(--tw-font-body); font-size: 13px;
      color: var(--tw-fg-muted);
    }
    .tw-404-panel-foot-icon {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: var(--tw-dark);
      color: var(--tw-gold);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .tw-404-panel-foot-icon svg { width: 14px; height: 14px; }
    .tw-404-panel-foot strong { color: var(--tw-dark); font-weight: 700; }
    .tw-404-panel-foot a { color: var(--tw-teal-500); text-decoration: none; font-weight: 600; }
    .tw-404-panel-foot a:hover { color: var(--tw-teal-700); text-decoration: underline; text-underline-offset: 3px; }

    /* ----- coordinates ticker ----- */
    .tw-404-coords {
      position: absolute; bottom: 28px; left: 32px; z-index: 6;
      display: flex; align-items: center; gap: 12px;
      color: rgba(254,252,248,0.55);
      font-family: var(--tw-font-mono); font-size: 11px;
      letter-spacing: 0.06em;
    }
    .tw-404-coords-line { width: 32px; height: 1px; background: rgba(254,252,248,0.3); }

    /* ----- responsive ----- */
    @media (max-width: 960px) {
      .tw-404-grid { grid-template-columns: 1fr; gap: 48px; padding: 64px 24px 90px; min-height: 0; }
      .tw-404-numeral { font-size: clamp(140px, 36vw, 220px); }
      .tw-404-coords { position: static; padding: 0 24px 24px; }
    }
  </style>

  <Topbar variant="homeowner" />
  <Header />

  <section class="tw-404">
    <div class="tw-404-bg"></div>
    <div class="tw-404-paper"></div>
    <div class="tw-404-vignette"></div>

    <div class="tw-404-grid">

      <!-- LEFT: numeral + copy + search -->
      <div>
        <div class="tw-404-eyebrow-row">
          <span class="tw-divider"></span>
          <span class="tw-eyebrow">Error 404 · Page Not Found</span>
        </div>

        <h1 class="tw-404-numeral" aria-label="404">
          4<span class="filled">0</span>4
        </h1>

        <h2 class="tw-404-title">
          This address isn&rsquo;t <em>on our map.</em>
        </h2>

        <p class="tw-404-lede">
          The page you were looking for may have moved, been renamed, or never existed. No harm done — let&rsquo;s point you back toward dry land. If you arrived from a link on our site, <a href="#contact">let us know</a> so we can fix it.
        </p>

        <form class="tw-404-search" id="tw-404-search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/>
          </svg>
          <input
            type="text"
            id="tw-404-query"
            placeholder="Search Tidewater — boards, residents, services…"
            aria-label="Search Tidewater"
          />
          <button type="submit">Search</button>
        </form>

        <div class="tw-404-actions" style="margin-top: 24px;">
          <a href="/" class="tw-btn tw-btn-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;">
              <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
            </svg>
            Back to homepage
          </a>
          <a href="#contact" class="tw-btn tw-btn-ghost">Report a broken link →</a>
        </div>
      </div>

      <!-- RIGHT: quick-return panel -->
      <aside class="tw-404-panel">
        <div class="tw-404-panel-head">
          <div class="tw-404-panel-eyebrow">Common destinations</div>
          <div class="tw-404-panel-meta">REF · /404</div>
        </div>

        <h3 class="tw-404-panel-title">Looking for one of these?</h3>
        <p class="tw-404-panel-sub">The most-visited corners of Tidewater — pick the one closest to what you needed.</p>

        <ul class="tw-404-links">
          <li>
            <a class="tw-404-link" href="/hoa-management">
              <div class="tw-404-link-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6l8-4z"/><path d="M9 12l2 2 4-4"/></svg>
              </div>
              <div class="tw-404-link-text">
                <div class="tw-404-link-title">HOA &amp; Condo Management</div>
                <div class="tw-404-link-sub">Full-service management for boards and associations.</div>
              </div>
              <span class="tw-404-link-arrow">→</span>
            </a>
          </li>
          <li>
            <a class="tw-404-link" href="/rental-management">
              <div class="tw-404-link-icon gold">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-8 9 8"/><path d="M5 10v10h14V10"/><path d="M10 20v-6h4v6"/></svg>
              </div>
              <div class="tw-404-link-text">
                <div class="tw-404-link-title">Rental Property Management</div>
                <div class="tw-404-link-sub">Single-family and small-multifamily rentals.</div>
              </div>
              <span class="tw-404-link-arrow">→</span>
            </a>
          </li>
          <li>
            <a class="tw-404-link" href="/maintenance-services">
              <div class="tw-404-link-icon sage">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 0 0 5.4-5.4l-2.5 2.5-2.5-2.5 2.5-2.5z"/></svg>
              </div>
              <div class="tw-404-link-text">
                <div class="tw-404-link-title">Property Maintenance</div>
                <div class="tw-404-link-sub">24/7 emergency response and trade services.</div>
              </div>
              <span class="tw-404-link-arrow">→</span>
            </a>
          </li>
          <li>
            <a class="tw-404-link" href="/resources">
              <div class="tw-404-link-icon clay">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h12a3 3 0 0 1 3 3v13a2 2 0 0 0-2-2H4z"/><path d="M4 4v14a2 2 0 0 0 2 2h13"/></svg>
              </div>
              <div class="tw-404-link-text">
                <div class="tw-404-link-title">Board Resources &amp; Insights</div>
                <div class="tw-404-link-sub">Playbooks, guides, and the seasonal library.</div>
              </div>
              <span class="tw-404-link-arrow">→</span>
            </a>
          </li>
        </ul>

        <div class="tw-404-panel-foot">
          <div class="tw-404-panel-foot-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.5 2L8 9.7a16 16 0 0 0 6 6l1.3-1.1a2 2 0 0 1 2-.5c.9.3 1.8.5 2.7.6A2 2 0 0 1 22 16.9z"/></svg>
          </div>
          <div>
            Already a board member or resident? Call <strong>(443) 548-0191</strong> or <a href="#">log in to the portal</a>.
          </div>
        </div>
      </aside>
    </div>

    <div class="tw-404-coords">
      <span>N 39°25'</span>
      <span class="tw-404-coords-line"></span>
      <span>W 76°48'</span>
      <span class="tw-404-coords-line"></span>
      <span>OWINGS MILLS · MD</span>
    </div>
  </section>

  <CTA />
  <Footer />

  <script>
    document.getElementById('tw-404-search')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const query = (document.getElementById('tw-404-query') as HTMLInputElement)?.value.trim();
      window.location.href = query
        ? `/resources/#search=${encodeURIComponent(query)}`
        : '/';
    });
  </script>
</BaseLayout>
