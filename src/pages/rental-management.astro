---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Header from '../components/Header.astro';
import RentalHero from '../components/RentalHero.astro';
import TrustBar from '../components/TrustBar.astro';
import RentalPains from '../components/RentalPains.astro';
import RentalFee from '../components/RentalFee.astro';
import RentalCounty from '../components/RentalCounty.jsx';
import RentalDeployed from '../components/RentalDeployed.astro';
import RentalPortal from '../components/RentalPortal.astro';
import Mission from '../components/Mission.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { serviceSchema, breadcrumbSchema } from '../lib/schema';
import { SITE } from '../config/site';

const pageUrl = `${SITE.url}/rental-management`;
const pageDesc = "One flat, all-inclusive fee. Full rental property management for landlords across Maryland and DC. Built for deployed, out-of-state, and second-home owners. Family-owned since 1989.";

const schemas = [
  serviceSchema({ name: 'Rental Property Management', description: pageDesc, url: pageUrl, areaServed: ['Maryland', 'Washington DC'] }),
  breadcrumbSchema([{ name: 'Home', url: SITE.url + '/' }, { name: 'Rental Management', url: pageUrl }]),
];
---
<BaseLayout
  title="Rental Property Management MD & DC | Tidewater"
  description={pageDesc}
  pageSchema={schemas}
>
  <Topbar variant="homeowner" />
  <Header activeNav="rental" />
  <Breadcrumb crumbs={[{ label: "Management", href: "/hoa-management/" }, { label: "Rental Management" }]} />
  <RentalHero />
  <TrustBar />
  <RentalPains />
  <RentalFee />
  <RentalCounty client:visible />
  <RentalDeployed />
  <RentalPortal />
  <Mission />
  <Testimonials />
  <CTA />
  <Footer />
</BaseLayout>
