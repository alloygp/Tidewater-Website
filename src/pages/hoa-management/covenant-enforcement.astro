---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Topbar from '../../components/Topbar.astro';
import Header from '../../components/Header.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import CovenantEnforcement from '../../components/CovenantEnforcement.jsx';
import FromTheBlog from '../../components/FromTheBlog.jsx';
import { breadcrumbSchema, serviceSchema } from '../../lib/schema';
import { SITE } from '../../config/site';

const pageUrl = `${SITE.url}/hoa-management/covenant-enforcement`;

const schemas = [
  serviceSchema({
    name: 'HOA Covenant Enforcement',
    description: 'Third-party HOA covenant enforcement across Maryland — consistent, documented violation process, real-time tracking in CINC, in-house administrative letter handling.',
    url: pageUrl,
    areaServed: 'Maryland',
  }),
  breadcrumbSchema([
    { name: 'Home', url: SITE.url + '/' },
    { name: 'HOA Management', url: SITE.url + '/hoa-management' },
    { name: 'Covenant Enforcement', url: pageUrl },
  ]),
];
---

<BaseLayout
  title="HOA Covenant Enforcement Maryland | Tidewater"
  description="Third-party HOA covenant enforcement for Maryland communities. Consistent, documented process — real-time CINC tracking, in-house admin team, full audit trail."
  ogType="website"
  pageSchema={schemas}
>
  <Topbar />
  <Header activeNav="mgmt" />
  <Breadcrumb crumbs={[
    { label: 'HOA Management', href: '/hoa-management' },
    { label: 'Covenant Enforcement' },
  ]} />
  <CovenantEnforcement client:load />
  <FromTheBlog client:load categories={['governance', 'hoa-mgmt']} />
  <CTA />
  <Footer />
</BaseLayout>
