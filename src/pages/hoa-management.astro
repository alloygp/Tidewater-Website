---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Pains from '../components/Pains.astro';
import Tiers from '../components/Tiers.astro';
import Mission from '../components/Mission.astro';
import HandsOn from '../components/HandsOn.astro';
import Portal from '../components/Portal.astro';
import Leadership from '../components/Leadership.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FromTheBlog from '../components/FromTheBlog.jsx';
import { serviceSchema, breadcrumbSchema } from '../lib/schema';
import { SITE } from '../config/site';

const pageUrl = `${SITE.url}/hoa-management`;
const pageDesc = "Family-owned HOA, condo, and co-op management for Maryland, DC, Virginia, Pennsylvania, Delaware, and West Virginia since 1989. AAMC® accredited.";

const schemas = [
  serviceSchema({
    name: 'HOA & Community Association Management',
    description: pageDesc,
    url: pageUrl,
  }),
  breadcrumbSchema([
    { name: 'Home', url: SITE.url + '/' },
    { name: 'HOA Management', url: pageUrl },
  ]),
];
---
<BaseLayout
  pageStylesheet="styles-blog.css"
  title="Tidewater Companies — HOA Management for the Mid-Atlantic"
  description={pageDesc}
  pageSchema={schemas}
>
  <Topbar variant="default" />
  <Header activeNav="hoa" logoSrc="/assets/Tidewater-Management-Logo.svg" logoAlt="Tidewater Management" />
  <Breadcrumb variant="management" crumbs={[{ label: "Management", href: "/hoa-management" }, { label: "HOA Management" }]} />
  <Hero config={{ heroWidget: 'fitcheck' }} />
  <TrustBar />
  <Pains />
  <Tiers />
  <Mission />
  <HandsOn />
  <Portal />
  <Leadership />

  <!-- Where We Manage geo strip -->
  <section class="tw-geo-section linen">
    <div class="tw-container">
      <div style="max-width:640px;margin-bottom:36px">
        <div style="font-family:var(--tw-font-heading);font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--tw-teal);margin-bottom:10px">Service Area</div>
        <h2 style="font-family:var(--tw-font-heading);font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;color:var(--tw-dark);margin:0 0 12px">HOA management across the Mid-Atlantic</h2>
        <p style="font-family:var(--tw-font-body);font-size:1rem;color:var(--tw-fg-muted);margin:0">We serve 400+ communities in Maryland, DC, Virginia, Delaware, Pennsylvania, and West Virginia. Explore county-level coverage, local regulations, and community profiles for your state.</p>
      </div>
      <div class="tw-geo-counties">
        <a href="/hoa-management/maryland" class="tw-geo-county-card featured">
          <div class="tw-geo-county-flag">MD</div>
          <div>
            <div class="tw-geo-county-head">
              <div class="tw-geo-county-name">Maryland</div>
              <div class="tw-geo-county-meta">Our largest service state · 20 counties</div>
            </div>
            <div class="tw-geo-county-body">Baltimore City &amp; County, Anne Arundel, Howard, Montgomery, Prince George\'s, Carroll, Harford, Frederick, and more.</div>
            <div class="tw-geo-county-cta">
              Explore Maryland coverage
              <svg class="tw-geo-county-cta-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;display:inline-block;vertical-align:middle;margin-left:4px"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </div>
          </div>
        </a>
        <div class="tw-geo-county-card" style="pointer-events:none;opacity:.65">
          <div class="tw-geo-county-flag">DC</div>
          <div>
            <div class="tw-geo-county-head">
              <div class="tw-geo-county-name">Washington, DC</div>
              <div class="tw-geo-county-meta">District communities &amp; investors</div>
            </div>
            <div class="tw-geo-county-body">Full-service condo and co-op management in the District.</div>
            <div class="tw-geo-county-cta" style="color:var(--tw-fg-muted)">Coverage page coming soon</div>
          </div>
        </div>
        <div class="tw-geo-county-card" style="pointer-events:none;opacity:.65">
          <div class="tw-geo-county-flag">VA</div>
          <div>
            <div class="tw-geo-county-head">
              <div class="tw-geo-county-name">Virginia</div>
              <div class="tw-geo-county-meta">Northern Virginia</div>
            </div>
            <div class="tw-geo-county-body">HOA and condo management in Fairfax, Arlington, Alexandria, and the greater NoVA corridor.</div>
            <div class="tw-geo-county-cta" style="color:var(--tw-fg-muted)">Coverage page coming soon</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Testimonials />
  <FromTheBlog client:load categories={['hoa-mgmt', 'governance']} />
  <CTA />
  <Footer />
</BaseLayout>
