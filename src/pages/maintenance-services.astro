---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Header from '../components/Header.astro';
import MaintenanceHero from '../components/MaintenanceHero.astro';
import TrustBar from '../components/TrustBar.astro';
import MaintenanceWhy from '../components/MaintenanceWhy.astro';
import MaintenanceServices from '../components/MaintenanceServices.astro';
import MaintenanceEmergency from '../components/MaintenanceEmergency.astro';
import Mission from '../components/Mission.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { serviceSchema, breadcrumbSchema } from '../lib/schema';
import { SITE } from '../config/site';

const pageUrl = `${SITE.url}/maintenance-services`;
const pageDesc = "In-house property maintenance and 24/7 emergency mitigation for owners, HOA boards, and rental clients across Maryland and Delaware.";

const schemas = [
  serviceSchema({ name: 'Property Maintenance Services', description: pageDesc, url: pageUrl, areaServed: ['Maryland', 'Delaware'] }),
  breadcrumbSchema([{ name: 'Home', url: SITE.url + '/' }, { name: 'Maintenance Services', url: pageUrl }]),
];
---
<BaseLayout
  title="Property Maintenance Services | Tidewater"
  description={pageDesc}
  bodyClass="tw-acc-sage"
  pageStylesheet="styles-pages.css"
  pageSchema={schemas}
>
  <Topbar variant="homeowner" />
  <Header activeNav="maintenance" />
  <Breadcrumb crumbs={[{ label: "Maintenance Services" }]} />
  <MaintenanceHero />
  <TrustBar />
  <MaintenanceWhy />
  <MaintenanceServices />
  <MaintenanceEmergency />
  <Mission />
  <Testimonials />
  <CTA
    eyebrow="Request a Maintenance Assessment"
    title="Let's talk about your property's maintenance needs."
    body="Tell us about your property and a member of our maintenance team will be in touch within one business day."
  />
  <Footer />
</BaseLayout>
