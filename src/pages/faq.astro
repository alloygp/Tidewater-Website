---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import FaqHub from '../components/FaqHub.jsx';
import { faqSchema, breadcrumbSchema } from '../lib/schema';
import { SITE } from '../config/site';

const faqItems = [
  { q: 'What does an HOA management company actually do?', a: 'A professional HOA management company handles the operational and financial machinery of running an association so the volunteer board can focus on governance. Day-to-day: financial (bookkeeping, assessment collection, vendor payments, budget, reserve study, audit), operational (vendor management, maintenance, covenant enforcement, ARC review, resident communication), and administrative (board meeting prep, minutes, elections, compliance filings, owner portal). The board sets policy; management executes.' },
  { q: "What's an AAMC, and why does it matter?", a: 'The Accredited Association Management Company (AAMC) designation is awarded by the Community Associations Institute (CAI). Fewer than 1% of management companies hold it. To qualify, a company must employ multiple PCAM-credentialed managers, maintain specific financial controls, carry adequate fidelity insurance, and pass a thorough operational audit. Tidewater is AAMC-accredited.' },
  { q: 'How long has Tidewater been around?', a: 'Family-owned since 1989. We manage 300+ communities across the Mid-Atlantic (Maryland, DC, Virginia, Pennsylvania, Delaware, West Virginia). Three offices: Owings Mills (HQ), Silver Spring, and the Eastern Shore.' },
  { q: "What's your typical response time?", a: 'Same business day, 95% of the time, on board email. After-hours emergencies get a manager callback within 30 minutes via our 24/7 line at (443) 548-0191.' },
  { q: 'Are your contracts long-term lock-ins?', a: 'No. Our standard agreement is a 12-month initial term with 30-day termination, no penalty, after that. Our 12-month retention rate is 97%.' },
  { q: 'What does Tidewater management cost?', a: 'For full-service management of an 80-250 door HOA in Maryland, fees typically run $28-$42 per unit per month. Financial-only management runs roughly 35-55% of full-service for a comparable community.' },
  { q: 'How do I log into the Owner Portal?', a: 'Go to portal.tidewaterproperty.com and use the email address your community has on file. If you are a new owner or never set up access, click "First-time login" and enter your property address — we will email you an invitation link.' },
  { q: 'How long does the transition from another company take?', a: 'Typically 7 weeks from signed proposal to first managed board meeting. Self-managed communities transition in 4-5 weeks. We run the transition on your behalf.' },
];

const schemas = [
  faqSchema(faqItems),
  breadcrumbSchema([
    { name: 'Home', url: SITE.url + '/' },
    { name: 'Resources', url: SITE.url + '/resources/' },
    { name: 'FAQ', url: SITE.url + '/faq/' },
  ]),
];
---
<BaseLayout
  title="HOA Management FAQ — Frequently Asked Questions | Tidewater"
  description="Common questions from HOA boards and homeowners about Tidewater management — CINC portal access, proposal evaluation, covenant enforcement, and more."
  pageSchema={schemas}
>
  <style is:global>
    /* ensure React island styles reach DOM */
  </style>
  <Topbar variant="default" />
  <Header activeNav="resources" />
  <FaqHub client:load />
  <Footer />
</BaseLayout>
