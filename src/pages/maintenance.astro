---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Header from '../components/Header.astro';
import MaintenanceHero from '../components/MaintenanceHero.astro';
import TrustBar from '../components/TrustBar.astro';
import MaintenanceWhy from '../components/MaintenanceWhy.astro';
import MaintenanceServices from '../components/MaintenanceServices.astro';
import MaintenanceEmergency from '../components/MaintenanceEmergency.astro';
import Mission from '../components/Mission.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Tidewater Property Maintenance — Reliable. Professional. Detail-Driven."
  description="In-house property maintenance and 24/7 emergency mitigation for owners, HOA boards, and rental clients across Maryland and Delaware."
  bodyClass="tw-acc-sage"
  pageStylesheet="styles-pages.css"
>
  <Topbar variant="homeowner" />
  <Header activeNav="maintenance" />
  <MaintenanceHero />
  <TrustBar />
  <MaintenanceWhy />
  <MaintenanceServices />
  <MaintenanceEmergency />
  <Mission />
  <Testimonials />
  <CTA />
  <Footer />
</BaseLayout>
