---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Topbar from '../../../components/Topbar.astro';
import Header from '../../../components/Header.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import Footer from '../../../components/Footer.astro';
import CTA from '../../../components/CTA.astro';
import RentalGeo, { GEO_DATA_MONTGOMERY_COUNTY as geo } from '../../../components/RentalGeo.jsx';
import { breadcrumbSchema, serviceSchema } from '../../../lib/schema';
import { SITE } from '../../../config/site';

const pageUrl = `${SITE.url}/rental-management/maryland/montgomery-county`;

const schemas = [
  serviceSchema({
    name: "Rental Property Management — Montgomery County, MD",
    description: geo.schemaDesc,
    url: pageUrl,
    areaServed: 'Montgomery County, Maryland',
  }),
  breadcrumbSchema([
    { name: 'Home', url: SITE.url + '/' },
    { name: 'Rental Management', url: SITE.url + '/rental-management' },
    { name: 'Maryland', url: SITE.url + '/rental-management/maryland' },
    { name: 'Montgomery County', url: pageUrl },
  ]),
];
---

<BaseLayout
  title="Montgomery County Rental Management | Tidewater"
  description="Rental property management in Montgomery County, MD — Rockville, Bethesda, Gaithersburg, Germantown, Wheaton. Rent stabilization tracked. Flat 8.5% fee. AppFolio-backed."
  ogType="website"
  pageSchema={schemas}
  pageStylesheet="styles-geo.css"
>
  <Topbar />
  <Header activeNav="rental" />
  <Breadcrumb crumbs={[
    { label: 'Rental Management', href: '/rental-management' },
    { label: 'Maryland', href: '/rental-management/maryland' },
    { label: 'Montgomery County' },
  ]} />
  <RentalGeo geo={geo} client:load />
  <CTA />
  <Footer />
</BaseLayout>
