---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Topbar from '../../../components/Topbar.astro';
import Header from '../../../components/Header.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import Footer from '../../../components/Footer.astro';
import CTA from '../../../components/CTA.astro';
import RentalGeo, { GEO_DATA_PRINCE_GEORGES_COUNTY as geo } from '../../../components/RentalGeo.jsx';
import { breadcrumbSchema, serviceSchema } from '../../../lib/schema';
import { SITE } from '../../../config/site';

const pageUrl = `${SITE.url}/rental-management/maryland/prince-georges-county`;

const schemas = [
  serviceSchema({
    name: "Rental Property Management — Prince George\'s County, MD",
    description: geo.schemaDesc,
    url: pageUrl,
    areaServed: "Prince George\'s County, Maryland",
  }),
  breadcrumbSchema([
    { name: 'Home', url: SITE.url + '/' },
    { name: 'Rental Management', url: SITE.url + '/rental-management' },
    { name: 'Maryland', url: SITE.url + '/rental-management/maryland' },
    { name: "Prince George\'s County", url: pageUrl },
  ]),
];
---

<BaseLayout
  title="Prince George\'s County Rental Management | Tidewater"
  description="Rental property management in Prince George\'s County, MD — Bowie, Largo, Greenbelt, Hyattsville. County license + lead-paint compliance handled. Flat 8.5% fee."
  ogType="website"
  pageSchema={schemas}
  pageStylesheet="styles-geo.css"
>
  <Topbar />
  <Header activeNav="rental" />
  <Breadcrumb crumbs={[
    { label: 'Rental Management', href: '/rental-management' },
    { label: 'Maryland', href: '/rental-management/maryland' },
    { label: "Prince George\'s County" },
  ]} />
  <RentalGeo geo={geo} client:load />
  <CTA />
  <Footer />
</BaseLayout>
