---
import AboutLayout from '../layouts/AboutLayout.astro';
import Topbar from '../components/Topbar.astro';
import Header from '../components/Header.astro';
import CareersHero from '../components/CareersHero.astro';
import NumbersStrip from '../components/NumbersStrip.astro';
import WhyWorkHere from '../components/WhyWorkHere.astro';
import JobsList from '../components/JobsList.jsx';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { breadcrumbSchema } from '../lib/schema';
import { SITE } from '../config/site';

const schemas = [
  breadcrumbSchema([{ name: 'Home', url: SITE.url + '/' }, { name: 'About', url: `${SITE.url}/about` }, { name: 'Careers', url: `${SITE.url}/careers` }]),
];
---
<AboutLayout
  title="Careers at Tidewater Property Management | Join Our Team"
  description="Join the largest privately-owned community management firm in the Mid-Atlantic. CAI designations paid upfront, in-house everything, real career runway."
  pageSchema={schemas}
>
  <Topbar variant="default" />
  <Header activeNav="about" />
  <Breadcrumb crumbs={[{ label: "About", href: "/about/" }, { label: "Careers" }]} />
  <CareersHero />
  <NumbersStrip />
  <WhyWorkHere />
  <JobsList client:load />
  <CTA />
  <Footer />
</AboutLayout>
