---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Topbar from '../components/Topbar.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import TestimonialsGrid from '../components/TestimonialsGrid.jsx';
import GoogleReviewsGrid from '../components/GoogleReviewsGrid.jsx';
import Breadcrumb from '../components/Breadcrumb.astro';
import { breadcrumbSchema } from '../lib/schema';
import { SITE } from '../config/site';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: SITE.url + '/' },
    { name: 'Testimonials', url: SITE.url + '/testimonials' },
  ]),
];
---
<BaseLayout pageSchema={schemas} title="HOA Board Reviews & Testimonials | Tidewater" description="What HOA and condo association boards across Maryland and the Mid-Atlantic say about working with Tidewater — reviews from boards we manage today.">
  <style is:global>
    /* page-level overrides if needed */
  </style>
  <Topbar variant="default" />
  <Header />
  <Breadcrumb crumbs={[
    { label: 'Testimonials' },
  ]} />

  <!-- Testimonials Hero -->
  <section class="tw-sol-hero">
    <div class="tw-sol-hero-paper"></div>
    <div class="tw-sol-hero-grid">
      <div class="tw-sol-hero-copy">
        <h1 class="tw-sol-hero-title">
          The boards who know us, <em>on the record.</em>
        </h1>
        <p class="tw-sol-hero-lede">
          Reviews from the people who hire us &mdash; named, attributed, and from communities you can call. We&rsquo;ve curated this page to board presidents, treasurers, and developers because they&rsquo;re the buyers; if you want the unfiltered resident view, our 552 Google reviews are one click away.
        </p>
        <div class="tw-sol-hero-actions">
          <a href="/request-a-proposal" class="tw-btn tw-btn-primary tw-btn-lg">Request a proposal &rarr;</a>
          <a href="#google-reviews" class="tw-btn tw-btn-ghost">What our communities say &rarr;</a>
        </div>
        <div class="tw-sol-hero-stats">
          <!-- PLACEHOLDER: replace with real board rating once data is collected -->
          <div>
            <div class="tw-sol-hero-stat-num gold">300+</div>
            <div class="tw-sol-hero-stat-label">Communities managed across the Mid-Atlantic</div>
          </div>
          <!-- PLACEHOLDER: replace with real board retention rate once confirmed -->
        </div>
      </div>

      <aside class="tw-sol-hero-side">
        <div style="padding:28px 30px 26px">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;padding-bottom:16px;border-bottom:1px solid var(--tw-border)">
            <div>
              <div style="font-family:var(--tw-font-heading);font-weight:700;font-size:10px;text-transform:uppercase;letter-spacing:0.16em;color:var(--tw-teal);margin-bottom:4px">From a board member</div>
              <div style="font-family:var(--tw-font-mono);font-size:10.5px;color:var(--tw-fg-subtle);letter-spacing:0.04em">GOOGLE REVIEW</div>
            </div>
            <div style="display:inline-flex;gap:2px;color:var(--tw-gold)">
              {[0,1,2,3,4].map(i => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ))}
            </div>
          </div>
          <blockquote style="font-family:var(--tw-font-heading);font-weight:300;font-style:italic;font-size:19px;line-height:1.45;color:var(--tw-dark);margin:0 0 22px;letter-spacing:-0.005em">
            &ldquo;Crystal at Tidewater cleaned up our community after a bad situation with another management company. She handles problems and is always there for us. She is amazing.&rdquo;
          </blockquote>
          <div style="display:flex;align-items:center;gap:14px;padding-top:18px;border-top:1px solid var(--tw-border)">
            <div style="width:42px;height:42px;border-radius:50%;background:var(--tw-teal);color:var(--tw-cream);display:flex;align-items:center;justify-content:center;font-family:var(--tw-font-heading);font-weight:800;font-size:14px">MV</div>
            <div>
              <div style="font-family:var(--tw-font-heading);font-weight:700;font-size:14px;color:var(--tw-dark);margin-bottom:2px">Mary Vosik</div>
              <div style="font-family:var(--tw-font-body);font-size:12px;color:var(--tw-fg-muted)">Treasurer &middot; Shoreview Woods</div>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- Context Strip (hidden) -->
  <section class="tw-tst-context" style="display:none">
    <div class="tw-tst-context-inner">
      <div class="tw-tst-context-note">
        <strong>About our Google reviews.</strong> Most of our 552 Google reviews come from individual residents in the 300+ communities we manage. Resident reviews tend to skew toward complaint (every late fee, every covenant letter), which is normal for the industry. We don&rsquo;t hide them &mdash; <a href="https://www.google.com/search?q=tidewater+property+management+maryland" target="_blank" rel="noopener">read every one here</a>. What you see on this page is curated for the board buyer.
      </div>
      <!-- PLACEHOLDER: replace with real board rating stats once collected -->
      <div class="tw-tst-context-stat" style="display:none">
      </div>
    </div>
  </section>

  <!-- Featured Quote — hidden until more board reviews are collected -->
  <section class="tw-tst-featured" style="display:none">
    <div class="tw-container-wide">
      <div class="tw-tst-featured-grid">
        <div>
          <div class="tw-tst-featured-eyebrow-row">
            <span class="tw-divider"></span>
            <span class="tw-eyebrow tw-eyebrow-gold">Featured &middot; Board Member Review</span>
          </div>
          <p class="tw-tst-featured-quote">
            Crystal Marine is by far the very best property Management Representative any organization could ever have. Crystal has demonstrated outstanding managerial ability in maintaining the Homestead HOA&rsquo;s diversified operations. Her complete understanding of HOA rules, long hours of work are an inspiration to those with whom she serves. Crystal Marine is the best!
          </p>
          <div class="tw-tst-featured-attr">
            <div class="tw-tst-featured-avatar">DS</div>
            <div>
              <div class="tw-tst-featured-name">David Seamen</div>
              <div class="tw-tst-featured-meta">
                <span class="accent">Board Member</span> &middot; Homestead HOA &middot; Maryland
                <div style="margin-top:4px;color:var(--tw-fg-subtle);font-family:var(--tw-font-mono);font-size:11px;letter-spacing:0.04em">GOOGLE REVIEW</div>
              </div>
            </div>
          </div>
        </div>

        <!-- PLACEHOLDER: Add a real client case study or metrics sidebar here once Tidewater provides data -->
        <aside class="tw-tst-featured-side" style="display:none">
          <!-- Hidden until real data is provided -->
        </aside>
      </div>
    </div>
  </section>

  <!-- Board reviews grid — hidden until more board reviews are collected -->
  <div style="display:none" aria-hidden="true">
    <TestimonialsGrid client:load />
  </div>

  <!-- Google reviews section -->
  <div id="google-reviews">
    <GoogleReviewsGrid client:load />
  </div>

  <CTA />
  <Footer />
</BaseLayout>
