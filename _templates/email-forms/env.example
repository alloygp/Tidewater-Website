# ── Resend ─────────────────────────────────────────────────────────
# Get from resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Mailchimp ───────────────────────────────────────────────────────
# API key: Mailchimp → Account → Extras → API Keys
# Server prefix: the letters/numbers before .api.mailchimp.com in your API URL (e.g. "us21")
# Audience ID: Mailchimp → Audience → Settings → Audience name & defaults → Audience ID
MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx-us21
MAILCHIMP_SERVER_PREFIX=us21
MAILCHIMP_AUDIENCE_ID=xxxxxxxxxxxx

# ── Internal notifications ──────────────────────────────────────────
# Who gets an email for every form submission (also add extras in email.config.ts notify array)
INTERNAL_NOTIFY_EMAIL=owner@clientsite.com
